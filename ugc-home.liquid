{%- comment -%} Homepage UGC / "Seen on the Dealers" grid — added by CRO audit. Lightweight image grid, blocks editable in the theme editor. {%- endcomment -%}
<div class="hd-ugc" style="padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="hd-ugc__head">
    {%- if section.settings.heading != blank -%}<h2 class="hd-ugc__title">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.subheading != blank -%}<p class="hd-ugc__sub">{{ section.settings.subheading }}</p>{%- endif -%}
  </div>
  <div class="hd-ugc__grid">
    {%- for block in section.blocks -%}
      {%- if block.settings.link != blank -%}
        <a class="hd-ugc__cell" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image_url != blank -%}<img src="{{ block.settings.image_url }}" alt="{{ block.settings.alt | escape }}" loading="lazy">{%- else -%}<span class="hd-ugc__ph">+</span>{%- endif -%}
        </a>
      {%- else -%}
        <div class="hd-ugc__cell" {{ block.shopify_attributes }}>
          {%- if block.settings.image_url != blank -%}<img src="{{ block.settings.image_url }}" alt="{{ block.settings.alt | escape }}" loading="lazy">{%- else -%}<span class="hd-ugc__ph">+</span>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  {%- if section.settings.cta_label != blank -%}
    <div class="hd-ugc__head"><a class="hd-ugc__cta" href="{{ section.settings.cta_link | default: '#' }}"{% if section.settings.cta_link != blank %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta_label }}</a></div>
  {%- endif -%}
</div>
<style>
  .hd-ugc{color:#f3ede0;font-family:inherit}
  .hd-ugc__head{text-align:center;max-width:1100px;margin:0 auto;padding:0 20px}
  .hd-ugc__title{font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:#e8b45a;margin:0 0 6px}
  .hd-ugc__sub{color:rgba(243,237,224,.6);font-size:14px;margin:0 0 22px}
  .hd-ugc__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;max-width:1100px;margin:0 auto;padding:0 6px}
  .hd-ugc__cell{position:relative;aspect-ratio:1/1;overflow:hidden;background:#16181d;display:block}
  .hd-ugc__cell img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s ease}
  a.hd-ugc__cell:hover img{transform:scale(1.05)}
  .hd-ugc__ph{display:flex;align-items:center;justify-content:center;height:100%;color:rgba(255,255,255,.18);font-size:30px}
  .hd-ugc__cta{display:inline-block;margin-top:22px;color:#e8b45a;border:1px solid #e8b45a;border-radius:8px;padding:11px 22px;font-size:12px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;text-decoration:none}
  .hd-ugc__cta:hover{background:#e8b45a;color:#231a06}
  @media(min-width:750px){.hd-ugc__grid{grid-template-columns:repeat(6,1fr)}}
</style>
{% schema %}
{
  "name": "UGC Gallery",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SEEN ON THE DEALERS" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Real people. Real drops." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Tag @thehatdealers to be featured" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 44 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 44 }
  ],
  "blocks": [
    { "type": "photo", "name": "Photo", "settings": [
      { "type": "text", "id": "image_url", "label": "Image URL", "info": "Paste a customer photo URL, or upload to Files and paste its link." },
      { "type": "url", "id": "link", "label": "Links to (optional)" },
      { "type": "text", "id": "alt", "label": "Alt text", "default": "The Hat Dealers customer" }
    ]}
  ],
  "presets": [{ "name": "UGC Gallery", "blocks": [{ "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }, { "type": "photo" }] }]
}
{% endschema %}
